{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eaglelab.ai/schemas/prd-flow/response.schema.json",
  "title": "PRD Flow Response Schema",
  "description": "Schema for prd_flow.run response payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "skillId",
    "requestId",
    "sessionId",
    "status",
    "stage",
    "nextAction",
    "result"
  ],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "skillId": {
      "type": "string",
      "const": "prd_flow"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "waiting_clarification",
        "ready_for_analysis",
        "ready_for_render",
        "completed",
        "failed",
        "aborted"
      ]
    },
    "stage": {
      "type": "string",
      "enum": ["clarify", "analyze", "render", "done", "failed", "intake"]
    },
    "nextAction": {
      "type": "string",
      "enum": ["answer_questions", "call_analyze", "call_render", "show_prd", "retry", "abort", "none"]
    },
    "message": {
      "type": "string"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "quality": {
      "$ref": "#/$defs/quality"
    },
    "error": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/error" }
      ]
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clarification", "analysis", "render"],
      "properties": {
        "clarification": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/clarificationResult" }
          ]
        },
        "analysis": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/analysisResult" }
          ]
        },
        "render": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/renderResult" }
          ]
        }
      }
    },
    "clarificationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "needClarification",
        "readyForAnalysis",
        "round",
        "remainingRounds",
        "missingFields",
        "questions",
        "summary"
      ],
      "properties": {
        "needClarification": {
          "type": "boolean"
        },
        "readyForAnalysis": {
          "type": "boolean"
        },
        "round": {
          "type": "integer",
          "minimum": 0
        },
        "remainingRounds": {
          "type": "integer",
          "minimum": 0
        },
        "missingFields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/missingField"
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/question"
          }
        },
        "summary": {
          "type": "string"
        },
        "stopReason": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "needClarification": { "const": false }
            },
            "required": ["needClarification"]
          },
          "then": {
            "properties": {
              "questions": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dimension", "label", "type", "required", "priority", "reason"],
      "properties": {
        "id": {
          "type": "string"
        },
        "dimension": {
          "$ref": "#/$defs/missingField"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["text", "single_select", "multi_select", "boolean"]
        },
        "required": {
          "type": "boolean"
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "placeholder": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["single_select", "multi_select"]
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["options"]
          },
          "else": {
            "not": {
              "required": ["options"]
            }
          }
        }
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "analysisResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meta": {
          "$ref": "#/$defs/meta"
        },
        "background": {
          "$ref": "#/$defs/background"
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role"
          }
        },
        "scenarios": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scenario"
          }
        },
        "functionalRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/functionalRequirement"
          }
        },
        "nonFunctionalRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonFunctionalRequirement"
          }
        },
        "dataAndIntegration": {
          "$ref": "#/$defs/dataAndIntegration"
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk"
          }
        },
        "diagram": {
          "$ref": "#/$defs/diagram"
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openQuestion"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/suggestion"
          }
        },
        "traceability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/traceability"
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["iot", "b_end", "c_end", "general"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "analysisConfidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "template": {
          "type": "string",
          "enum": ["lite", "standard", "full"]
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "problem": {
          "$ref": "#/$defs/contentWithSource"
        },
        "goal": {
          "$ref": "#/$defs/contentWithSource"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inScope": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/contentWithSource"
              }
            },
            "outOfScope": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/contentWithSource"
              }
            }
          }
        }
      }
    },
    "contentWithSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "sourceStatus"],
      "properties": {
        "content": {
          "type": "string"
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "sourceStatus"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "actors", "preconditions", "sourceStatus"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "functionalRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module",
        "feature",
        "description",
        "priority",
        "actors",
        "businessRules",
        "normalFlow",
        "exceptionFlows",
        "acceptanceCriteria",
        "sourceStatus"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "feature": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "businessRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "normalFlow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exceptionFlows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "nonFunctionalRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "content", "sourceStatus"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["performance", "security", "availability", "audit", "compliance", "usability"]
        },
        "content": {
          "type": "string"
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "dataAndIntegration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataObjects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/namedObjectWithSource"
          }
        },
        "integrations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/namedObjectWithSource"
          }
        }
      }
    },
    "namedObjectWithSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "sourceStatus"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "type", "sourceStatus"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["business", "efficiency", "stability", "experience"]
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "impact", "mitigation", "sourceStatus"],
      "properties": {
        "title": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "mitigation": {
          "type": "string"
        },
        "sourceStatus": {
          "$ref": "#/$defs/sourceStatus"
        }
      }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diagramNeeded": {
          "type": "boolean"
        },
        "diagramType": {
          "type": "string",
          "enum": ["flowchart", "sequence", "state", "none"]
        },
        "reason": {
          "type": "string"
        },
        "textFlow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "openQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "impact", "severity"],
      "properties": {
        "id": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "content", "type"],
      "properties": {
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["role", "metric", "exception", "scope", "interaction", "compliance"]
        }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "source"],
      "properties": {
        "targetId": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "renderResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "markdown"],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "markdown": {
          "type": "string"
        },
        "artifacts": {
          "$ref": "#/$defs/artifacts"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileArtifact"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hasMermaid": {
          "type": "boolean"
        },
        "diagramType": {
          "type": "string",
          "enum": ["flowchart", "sequence", "state", "none"]
        },
        "mermaid": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "fileArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contentType", "suggestedPath"],
      "properties": {
        "name": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        },
        "suggestedPath": {
          "type": "string"
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaValid", "warnings"],
      "properties": {
        "analysisConfidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "schemaValid": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "missingRequiredSections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "hasPendingConfirmation": {
              "type": "boolean"
            },
            "hasInferredContent": {
              "type": "boolean"
            },
            "renderConsistentWithAnalysis": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "INVALID_REQUEST",
            "INVALID_STATE",
            "UNSUPPORTED_MODE",
            "SCHEMA_VALIDATION_FAILED",
            "CLARIFICATION_REQUIRED",
            "ANALYSIS_FAILED",
            "RENDER_FAILED",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "sourceStatus": {
      "type": "string",
      "enum": ["explicit", "inferred", "pending_confirmation"]
    },
    "missingField": {
      "type": "string",
      "enum": [
        "goal",
        "persona",
        "scope",
        "flow",
        "permission",
        "constraint",
        "integration",
        "metric",
        "risk"
      ]
    }
  }
}